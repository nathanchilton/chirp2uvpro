{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8089/v1",
        "toolParser": [
          { "type": "json" }
        ]
      },
      "models": {
        "gemma4-26b": {
          "name": "Gemma 4 26B",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 16384
          }
        },
        "qwen3.5-9b": {
          "name": "Qwen 3.5 9B",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 16384
          }
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 12000
  },
  "model": "llama/gemma4-26b",
  "agent": {
    "build": {
      "steps": 75,
      "prompt": "{file:./.opencode/prompts/build.txt}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow"
      }
    }
  }
}
